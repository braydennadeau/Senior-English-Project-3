<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Benefits of Video Games </title>
    <style>
        /* CSS STYLES */
        :root {
            --bg-color: #0b0f19;
            --text-main: #e2e8f0;
            --accent-color: #00e5ff;
            --box-bg: #1e293b;
            --track-bg: #334155;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-main);
            margin: 0;
            padding: 0;
            line-height: 1.6;
            transition: background-color 0.3s, color 0.3s;
        }

        /* Light Mode Variables */
        body.light-mode {
            --bg-color: #f8fafc;
            --text-main: #0f172a;
            --box-bg: #e2e8f0;
            --track-bg: #cbd5e1;
        }
        
        body.light-mode h3, 
        body.light-mode .info-card h4,
        body.light-mode .surgeon-card .stat-title {
            color: #0f172a;
        }
        
        body.light-mode .info-card p,
        body.light-mode .brain-card p,
        body.light-mode .surgeon-card .stat-desc {
            color: #475569;
        }

        body.light-mode .brain-card h5 {
            color: #0f172a;
        }

        /* Navigation */
        nav {
            background-color: #000;
            padding: 15px 20px;
            text-align: center;
            position: sticky;
            top: 0;
            z-index: 100;
            border-bottom: 2px solid var(--accent-color);
            display: flex;
            justify-content: center;
            align-items: center;
            flex-wrap: wrap;
        }

        nav a {
            color: #fff;
            text-decoration: none;
            margin: 0 15px;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: color 0.3s;
        }

        nav a:hover {
            color: var(--accent-color);
        }

        #theme-toggle {
            background: none;
            border: 1px solid var(--accent-color);
            color: var(--accent-color);
            padding: 5px 15px;
            border-radius: 20px;
            cursor: pointer;
            font-weight: bold;
            margin-left: 20px;
            transition: all 0.3s;
        }

        #theme-toggle:hover {
            background: var(--accent-color);
            color: #000;
        }

        /* Hero Section */
        header {
            text-align: center;
            padding: 100px 20px;
            background: linear-gradient(rgba(11, 15, 25, 0.8), rgba(11, 15, 25, 1)), url('https://images.unsplash.com/photo-1542751371-adc38448a05e?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80') center/cover;
            border-bottom: 1px solid #333;
        }

        header h1 {
            font-size: 3em;
            color: var(--accent-color);
            margin-bottom: 10px;
            text-shadow: 0 0 10px rgba(0, 229, 255, 0.5);
        }

        header p.subtitle {
            font-size: 1.2em;
            max-width: 600px;
            margin: 0 auto 20px auto;
        }

        header p.byline {
            font-style: italic;
            color: #94a3b8;
        }

        /* Main Content Container */
        .container {
            max-width: 900px;
            margin: 40px auto;
            padding: 0 20px;
        }

        /* Typography & Spacing */
        h2 {
            color: var(--accent-color);
            border-bottom: 2px solid #333;
            padding-bottom: 5px;
            margin-top: 40px;
        }

        h3 {
            color: var(--text-main);
            margin-top: 30px;
        }

        p {
            margin-bottom: 20px;
            font-size: 1.05em;
        }

        /* Quick Facts Sidebar / Highlight Box */
        .quick-facts {
            background-color: var(--box-bg);
            border-left: 5px solid var(--accent-color);
            padding: 20px;
            margin: 30px 0;
            border-radius: 0 8px 8px 0;
            box-shadow: 0 4px 6px rgba(0,0,0,0.3);
            transition: background-color 0.3s;
        }

        .quick-facts h3 {
            margin-top: 0;
            color: var(--accent-color);
        }

        .quick-facts ul {
            list-style-type: none;
            padding-left: 0;
        }

        .quick-facts li {
            margin-bottom: 10px;
            padding-left: 30px;
            position: relative;
        }

        .quick-facts li::before {
            content: '🎮';
            position: absolute;
            left: 0;
            color: var(--accent-color);
        }

        /* Infographic Section */
        .infographic {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 20px;
            margin: 40px 0;
        }

        .info-card {
            background-color: var(--box-bg);
            padding: 20px;
            text-align: center;
            border-radius: 8px;
            border-top: 3px solid var(--accent-color);
            transition: transform 0.3s, background-color 0.3s;
        }

        .info-card:hover {
            transform: translateY(-5px);
        }

        .info-card h4 {
            color: var(--text-main);
            margin-top: 10px;
            margin-bottom: 5px;
        }

        .info-card p {
            font-size: 0.9em;
            color: #cbd5e1;
            margin: 0;
        }

        .icon {
            font-size: 2em;
        }

        /* Images */
        .content-image {
            width: 100%;
            height: auto;
            border-radius: 8px;
            margin: 30px 0;
            box-shadow: 0 4px 15px rgba(0,0,0,0.5);
        }

        /* Works Cited Section */
        .works-cited {
            background-color: var(--box-bg);
            padding: 40px 20px;
            margin-top: 60px;
            border-top: 1px solid #333;
            transition: background-color 0.3s;
        }

        .works-cited .container {
            margin-top: 0;
            margin-bottom: 0;
        }

        .citation {
            padding-left: 30px;
            text-indent: -30px;
            margin-bottom: 15px;
            color: #94a3b8;
            font-size: 0.9em;
            word-wrap: break-word;
        }
        
        .citation a {
            color: var(--accent-color);
            text-decoration: none;
        }

        .citation a:hover {
            text-decoration: underline;
        }

        /* =========================================
           INFOGRAPHIC CSS STYLES 
           ========================================= */
        .visual-stat-box {
            background-color: var(--box-bg);
            border-radius: 12px;
            padding: 30px;
            margin: 40px 0;
            box-shadow: 0 10px 20px rgba(0,0,0,0.3);
            border-top: 4px solid var(--accent-color);
            transition: background-color 0.3s;
        }

        /* Brain Grid */
        .brain-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
            margin-top: 25px;
        }
        
        .brain-card {
            background-color: var(--track-bg);
            padding: 20px;
            border-radius: 8px;
            border-left: 4px solid var(--accent-color);
            transition: transform 0.2s, background-color 0.3s;
        }

        .brain-card:hover {
            transform: scale(1.03);
        }

        .brain-card h5 {
            margin: 0 0 8px 0;
            color: var(--text-main);
            font-size: 1.15em;
        }

        .brain-card p {
            margin: 0;
            font-size: 0.9em;
            color: #cbd5e1;
            line-height: 1.4;
        }

        /* New Surgeon Stat Cards */
        .surgeon-card-container {
            display: flex; 
            justify-content: center; 
            gap: 20px; 
            flex-wrap: wrap;
            margin-top: 20px;
        }

        .surgeon-card {
            background-color: var(--track-bg);
            padding: 25px 20px;
            border-radius: 10px;
            width: 220px;
            text-align: center;
            border-bottom: 5px solid var(--accent-color);
            transition: transform 0.2s, background-color 0.3s;
        }

        .surgeon-card:hover {
            transform: translateY(-5px);
        }

        .surgeon-card.green {
            border-bottom-color: #22c55e;
        }

        .surgeon-card .stat-num {
            font-size: 3em;
            font-weight: bold;
            color: var(--accent-color);
            line-height: 1;
        }

        .surgeon-card.green .stat-num {
            color: #22c55e;
        }

        .surgeon-card .stat-title {
            font-weight: bold;
            margin-top: 10px;
            font-size: 1.1em;
            color: var(--text-main);
        }

        .surgeon-card .stat-desc {
            font-size: 0.85em;
            color: #94a3b8;
            margin-top: 10px;
            line-height: 1.4;
        }

    </style>
</head>
